# Get your v0 API key here: https://v0.dev/chat/settings/keys
V0_API_KEY="your_v0_api_key"

# Optional: for rate limiting
KV_REST_API_URL=your_upstash_redis_rest_url
KV_REST_API_TOKEN=your_upstash_redis_rest_token

# Calendly webhook (from webhook subscription signing_key)
CALENDLY_SIGNING_KEY=your_calendly_webhook_signing_key

# Follow Up Boss — Admin > API (server-side only)
FOLLOW_UP_BOSS_API_KEY=your_follow_up_boss_api_key
