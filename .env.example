# Get your v0 API key here: https://v0.dev/chat/settings/keys
V0_API_KEY="your_v0_api_key"

# Google Search Console — HTML meta tag verification (Settings > Ownership > HTML tag)
# Add in Vercel: Project Settings > Environment Variables > Production + Preview
GOOGLE_SITE_VERIFICATION="your_gsc_verification_token"

# Optional: for rate limiting
KV_REST_API_URL=your_upstash_redis_rest_url
KV_REST_API_TOKEN=your_upstash_redis_rest_token
